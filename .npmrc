# Use exact versions for consistency
save-exact=true

# Use pnpm's default node linker
node-linker=hoisted

# Strict peer dependencies (recommended for pnpm)
strict-peer-dependencies=true

# Auto-install peers (set to false for more control)
auto-install-peers=false

# GitHub Package Registry for @virtualdisplay-io scope
@virtualdisplay-io:registry=https://npm.pkg.github.com/
