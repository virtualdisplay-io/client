{
  "name": "@virtual-display/client",
  "version": "1.0.0",
  "main": "dist/virtual-display-client.cjs.js",
  "module": "dist/virtual-display-client.es.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "analyze": "vite-bundle-visualizer --template treemap --output stats.html --open false",
    "build": "tsc && vite build",
    "dev": "vite",
    "test": "vitest run",
    "release": "semantic-release",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "lint": "eslint src --ext .ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/virtual-display-client.es.js",
      "require": "./dist/virtual-display-client.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/virtualdisplay-io/client.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^11.0.0",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.4.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.4.1",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
