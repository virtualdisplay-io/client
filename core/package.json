{
  "name": "@virtualdisplay-io/client",
  "version": "3.0.0",
  "main": "dist/virtualdisplay.client.cjs.js",
  "module": "dist/virtualdisplay.client.es.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "analyze": "vite-bundle-visualizer --template treemap --output stats.html --open false",
    "build": "tsc && vite build",
    "prepare": "pnpm build",
    "dev": "vite",
    "test": "vitest run",
    "test:a11y": "vitest run tests/unit/accessibility.test.ts tests/unit/iframe/builder.accessibility.test.ts",
    "test:watch": "vitest",
    "release": "semantic-release",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"tests/**/*.{ts,json}\"",
    "lint": "eslint . --ext .ts",
    "lint:a11y": "eslint . --ext .ts --config .eslintrc.a11y.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/virtualdisplay.client.es.js",
      "require": "./dist/virtualdisplay.client.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "../LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virtualdisplay-io/client.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^24.0.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "jsdom": "^26.1.0",
    "semantic-release": "^24.2.4",
    "vitest": "^3.2.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@virtualdisplay-io/logger": "^1.1.2"
  }
}
